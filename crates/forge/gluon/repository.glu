
// Pure embedded API imported by repository fragments as `cast.repository.v1`.

type Optional a =
    | None
    | Some a

type Boolean =
    | False
    | True

type RepositorySourceSpec =
    | DirectIndex { uri: String }
    | RootIndex {
        base_uri: String,
        channel: Optional String,
        version: String,
        arch: Optional String,
    }

type RepositorySpec = {
    id: String,
    description: Optional String,
    source: RepositorySourceSpec,
    priority: Optional Int,
    enabled: Optional Boolean,
}

let direct = \id uri -> {
    id,
    description = None,
    source = DirectIndex { uri },
    priority = None,
    enabled = None,
}

let direct_with = \value -> {
    id = value.id,
    description = value.description,
    source = DirectIndex { uri = value.uri },
    priority = value.priority,
    enabled = value.enabled,
}

let root_index = \id base_uri version -> {
    id,
    description = None,
    source = RootIndex {
        base_uri,
        channel = None,
        version,
        arch = None,
    },
    priority = None,
    enabled = None,
}

let root_index_with = \value -> {
    id = value.id,
    description = value.description,
    source = RootIndex {
        base_uri = value.base_uri,
        channel = value.channel,
        version = value.version,
        arch = value.arch,
    },
    priority = value.priority,
    enabled = value.enabled,
}

let repositories: Array RepositorySpec -> Array RepositorySpec = \values -> values

{
    abi_version = 1,
    repositories,
    optional = {
        none = None,
        some = \value -> Some value,
    },
    boolean = {
        false = False,
        true = True,
    },
    defaults = {
        description = "",
        channel = "main",
        arch = "x86_64",
        priority = 0,
        enabled = True,
    },
    repository = {
        direct,
        direct_with,
        root = root_index,
        root_index,
        root_with = root_index_with,
        root_index_with,
    },
}
