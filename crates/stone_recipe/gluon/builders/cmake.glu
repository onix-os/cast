let b = import! boulder.package.v2

let defaults = {
    flags = [],
    run_tests = b.boolean.true,
}

{
    abi_version = 1,
    defaults,
    builder = \config -> b.builder.cmake config,
    default = b.builder.cmake defaults,
}
