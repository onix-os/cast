let b = import! boulder.package.v2

let defaults = {
    flags = [],
    run_tests = b.boolean.true,
}

let builder = \config -> b.builder.structured {
    required_tools = [
        b.dep.binary "cmake",
        b.dep.binary "ninja",
        b.dep.binary "ctest",
    ],
    environment = [b.environment.cmake],
    phases = b.scripts {
        setup = b.phase [b.step.cmake_configure config.flags],
        build = b.phase [b.step.cmake_build],
        install = b.phase [b.step.cmake_install],
        check = b.phase (b.boolean.when config.run_tests [b.step.cmake_test]),
        .. b.defaults.scripts
    },
    supported_hooks = b.hook_support.all,
}

{
    abi_version = 1,
    defaults,
    builder,
    default = builder defaults,
}
