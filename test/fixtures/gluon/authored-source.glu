let boulder = import! boulder.recipe.v1
let base = boulder.recipe (boulder.source {
    name = "example",
    version = "1.2.3",
    release = 1,
    homepage = "https://example.com",
    license = ["MPL-2.0"],
})
{
    upstreams = [
        boulder.upstream.archive
            "https://example.com/source.tar.xz"
            "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        boulder.upstream.git "https://example.com/source.git" "main",
    ],
    .. base
}
