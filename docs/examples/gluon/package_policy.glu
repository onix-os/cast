let boulder = import! boulder.package.v3

\output ->
    let output = boulder.output_with output
    {
        summary = boulder.optional.set "Recipe composed with an imported policy",
        runtime_inputs = [boulder.dep.package "ca-certificates"],
        .. output
    }
