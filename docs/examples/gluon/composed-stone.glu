
let cast = import! cast.package.v3
let package_policy = import! "./package_policy.glu"

let meta = cast.meta {
    pname = "composed-hello",
    version = "1.0.0",
    release = 1,
    homepage = "https://example.invalid/composed-hello",
    license = ["MPL-2.0"],
}

{
    outputs = cast.outputs.with_root meta.pname (package_policy (cast.output "out")),
    .. cast.mk_package meta
}
