let boulder = import! boulder.package.v2
let package_policy = import! "./package_policy.glu"

let meta = boulder.meta {
    pname = "composed-hello",
    version = "1.0.0",
    release = 1,
    homepage = "https://example.invalid/composed-hello",
    license = ["MPL-2.0"],
}

{
    outputs = boulder.outputs.with_root meta.pname (package_policy (boulder.output "out")),
    .. boulder.mk_package meta
}
