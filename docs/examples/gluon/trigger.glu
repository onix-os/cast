let moss = import! moss.trigger.v1
let base = moss.trigger "refresh-example" "Refresh generated example data"

{
    paths = [
        moss.path
            "/usr/share/example/(name:*)"
            ["refresh"]
            moss.optional.unset,
    ],
    handlers = [
        moss.handler.named "refresh" (moss.handler.run
            "/usr/bin/example-refresh"
            ["$(name)"]),
    ],
    .. base
}
