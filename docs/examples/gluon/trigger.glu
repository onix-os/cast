let cast = import! cast.trigger.v1
let base = cast.trigger "refresh-example" "Refresh generated example data"

{
    paths = [
        cast.path
            "/usr/share/example/(name:*)"
            ["refresh"]
            cast.optional.unset,
    ],
    handlers = [
        cast.handler.named "refresh" (cast.handler.run
            "/usr/bin/example-refresh"
            ["$(name)"]),
    ],
    .. base
}
