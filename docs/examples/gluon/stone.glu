
let cast = import! cast.package.v3

let base = cast.mk_package (cast.meta {
    pname = "hello",
    version = "1.0.0",
    release = 1,
    homepage = "https://example.invalid/hello",
    license = ["MPL-2.0"],
})

{
    outputs = cast.outputs.with_root base.meta.pname {
        summary = cast.optional.set "Minimal Gluon recipe example",
        .. cast.output "out"
    },
    .. base
}
