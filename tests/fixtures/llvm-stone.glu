let b = import! boulder.package.v2

let scripts = b.scripts {
    setup = b.optional.set "%cmake -S llvm -DLLVM_BUILD_LLVM_DYLIB=ON -DLLVM_ENABLE_PROJECTS=clang;lld",
    build = b.optional.set "%cmake_build",
    install = b.optional.set "%cmake_install",
    environment = b.optional.set "export LD_LIBRARY_PATH=%(workdir)/%(builddir)/lib",
    .. b.defaults.scripts
}

let root = {
    summary = b.optional.set "Low Level Virtual Machine",
    description = b.optional.set "Low Level Virtual Machine",
    .. b.output "out"
}
let development = {
    paths = [
        b.path.any "/usr/bin/FileCheck",
        b.path.any "/usr/bin/obj2yaml",
        b.path.any "/usr/bin/yaml2obj",
    ],
    .. b.output "devel"
}
let libraries = {
    summary = b.optional.set "Library files for llvm",
    paths = [b.path.any "/usr/lib/libLLVM-*.so"],
    .. b.output "libs"
}
let clang = {
    summary = b.optional.set "Clang compiler front-end (LLVM)",
    runtime_inputs = [
        b.dep.package "libcxx-devel",
        b.dep.output (b.package_ref "llvm") "lld",
        b.dep.output (b.package_ref "llvm") "out",
    ],
    paths = [
        b.path.any "/usr/bin/*clang*",
        b.path.any "/usr/lib/clang",
        b.path.any "/usr/share/clang",
    ],
    .. b.output "clang"
}
let clang_development = {
    summary = b.optional.set "Development files for clang",
    runtime_inputs = [b.dep.output (b.package_ref "llvm") "clang"],
    paths = [
        b.path.any "/usr/lib/cmake/clang",
        b.path.any "/usr/lib/libclang*.a",
        b.path.any "/usr/include/clang*",
    ],
    .. b.output "clang-devel"
}
let lld = {
    summary = b.optional.set "LLVM linker",
    paths = [b.path.any "/usr/bin/*lld*", b.path.any "/usr/bin/wasm-ld"],
    .. b.output "lld"
}
let lld_development = {
    summary = b.optional.set "Development files for lld",
    runtime_inputs = [b.dep.output (b.package_ref "llvm") "lld"],
    paths = [b.path.any "/usr/lib/cmake/lld", b.path.any "/usr/lib/liblld*.a"],
    .. b.output "lld-devel"
}

{
    builder = b.builder.shell scripts [
        b.dep.binary "cmake",
        b.dep.binary "ninja",
        b.dep.binary "perl",
        b.dep.binary "python3",
    ],
    build_inputs = [
        b.dep.pkgconfig "libffi",
        b.dep.pkgconfig "libxcrypt",
        b.dep.pkgconfig "libxml-2.0",
        b.dep.pkgconfig "ncursesw",
        b.dep.pkgconfig "zlib",
        b.dep.package "binutils-devel",
        b.dep.package "gcc-32bit-devel",
        b.dep.package "glibc-32bit-devel",
        b.dep.package "libcxx-32bit-devel",
        b.dep.package "clang-32bit",
    ],
    outputs = [root, development, libraries, clang, clang_development, lld, lld_development],
    sources = [
        b.source.archive
            "https://github.com/llvm/llvm-project/releases/download/llvmorg-16.0.4/llvm-project-16.0.4.src.tar.xz"
            "cf3c2a1152ed7a99866bd7f12c24528ada6d9f6336afb7a08416938762004c9f",
    ],
    tuning = [
        b.named "bolt" b.tuning.enable,
        b.named "fortify" b.tuning.disable,
        b.named "harden" b.tuning.disable,
        b.named "icf" (b.tuning.config "all"),
        b.named "lto" b.tuning.disable,
        b.named "nosemantic" b.tuning.enable,
        b.named "optimize" (b.tuning.config "speed"),
        b.named "polly" b.tuning.enable,
        b.named "symbolic" b.tuning.enable,
    ],
    .. b.mk_package (b.meta {
        pname = "llvm",
        version = "16.0.4",
        release = 8,
        homepage = "https://www.llvm.org",
        license = ["Apache-2.0 WITH LLVM-exception", "NCSA"],
    })
}
