            },
        },
    ],
    upstreams = [
        Archive {
            url = "https://github.com/llvm/llvm-project/releases/download/llvmorg-16.0.4/llvm-project-16.0.4.src.tar.xz",
            hash = "cf3c2a1152ed7a99866bd7f12c24528ada6d9f6336afb7a08416938762004c9f",
            rename = Unset,
            strip_dirs = Unset,
            unpack = True,
            unpack_dir = Unset,
        },
    ],
    architectures = [
    ],
    tuning = [
        {
            key = "bolt",
            value = Enable,
        },
        {
            key = "fortify",
            value = Disable,
        },
        {
            key = "harden",
            value = Disable,
        },
        {
            key = "icf",
            value = Config {
                value = "all",
            },
        },
        {
            key = "lto",
            value = Disable,
        },
        {
            key = "nosemantic",
            value = Enable,
        },
        {
            key = "optimize",
            value = Config {
                value = "speed",
            },
        },
        {
            key = "polly",
            value = Enable,
        },
        {
            key = "symbolic",
            value = Enable,
        },
    ],
    emul32 = False,
    mold = False,
}
