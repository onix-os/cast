let b = import! boulder.package.v2

let scripts = b.scripts {
    setup = b.phase [b.step.shell "for f in a b c d e f g h; do touch $f; done"],
    build = b.phase [b.step.shell "for f in a b c d e f g h; do echo $f >> build.log; done"],
    install = b.phase [
        b.step.shell r#"install -Dm00644 build.log "${BOULDER_INSTALL_ROOT}${BOULDER_LIBEXECDIR}/build.log""#,
    ],
    .. b.defaults.scripts
}

let root = {
    summary = b.optional.set "Concurrency test for boulder",
    description = b.optional.set "Concurrency test for boulder",
    .. b.output "out"
}

{
    builder = b.builder.shell scripts [],
    outputs = b.outputs.with_root "boulder-concurrency-test" root,
    .. b.mk_package (b.meta {
        pname = "boulder-concurrency-test",
        version = "1",
        release = 1,
        homepage = "https://github.com/serpent-os/moss",
        license = ["MPL-2.0"],
    })
}
