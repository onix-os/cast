let b = import! boulder.package.v2
let scripts = b.scripts {
    install = b.optional.set "mkdir -p %(installroot)/%(vendordir) && touch %(installroot)/%(vendordir)/pineapple",
    .. b.defaults.scripts
}
let root = {
    summary = b.optional.set "Delicious slices of pineapples",
    description = b.optional.set "Can I be on your pizza?",
    .. b.output "out"
}
{
    builder = b.builder.shell scripts [],
    outputs = [root],
    .. b.mk_package (b.meta {
        pname = "pineapple",
        version = "1",
        release = 1,
        homepage = "https://github.com/serpent-os",
        license = ["Zlib"],
    })
}
