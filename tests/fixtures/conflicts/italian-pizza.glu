let b = import! boulder.package.v2
let scripts = b.scripts {
    install = b.phase [
        b.step.shell r#"mkdir -p "${BOULDER_INSTALL_ROOT}${BOULDER_VENDORDIR}" && touch "${BOULDER_INSTALL_ROOT}${BOULDER_VENDORDIR}/italian-pizza""#,
    ],
    .. b.defaults.scripts
}
let root = {
    summary = b.optional.set "A certain Italian pizza that hates pineapples",
    description = b.optional.set "Me no like pineapples.",
    conflicts = [b.dep.package "pineapple"],
    .. b.output "out"
}
{
    builder = b.builder.shell scripts [],
    outputs = b.outputs.with_root "italian-pizza" root,
    .. b.mk_package (b.meta {
        pname = "italian-pizza",
        version = "1",
        release = 1,
        homepage = "https://github.com/serpent-os",
        license = ["Zlib"],
    })
}
