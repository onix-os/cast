
let cast = import! cast.package.v3
let base = cast.mk_package (cast.meta {
    pname = "example",
    version = "1.2.3",
    release = 1,
    homepage = "https://example.com",
    license = ["MPL-2.0"],
})
{
    sources = [
        cast.source.archive
            "https://example.com/source.tar.xz"
            "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        cast.source.git "https://example.com/source.git" "main",
    ],
    .. base
}
