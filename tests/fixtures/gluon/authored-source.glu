let boulder = import! boulder.package.v2
let base = boulder.mk_package (boulder.meta {
    pname = "example",
    version = "1.2.3",
    release = 1,
    homepage = "https://example.com",
    license = ["MPL-2.0"],
})
{
    sources = [
        boulder.source.archive
            "https://example.com/source.tar.xz"
            "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        boulder.source.git "https://example.com/source.git" "main",
    ],
    .. base
}
