#!/usr/bin/dash

set -eu

for argument do
    case "$argument" in
        --*=*|--disable-*|--enable-*) ;;
        *) printf 'unsupported configure argument: %s\n' "$argument" >&2; exit 2 ;;
    esac
done

printf '%s\n' \
    'CC ?= cc' \
    'CFLAGS ?=' \
    'all: cast-autotools-fixture' \
    'cast-autotools-fixture: hello.c' \
    '	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ hello.c' \
    'check: cast-autotools-fixture' \
    '	./cast-autotools-fixture >/dev/null' \
    'install: cast-autotools-fixture' \
    '	install -Dm755 cast-autotools-fixture "$(DESTDIR)/usr/bin/cast-autotools-fixture"' \
    > Makefile
