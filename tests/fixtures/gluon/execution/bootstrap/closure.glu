// Exact contentful bootstrap closure for the offline execution fixtures.
// Package names, versions, sizes, URLs, outputs, and dependency edges are
// derived from the pinned immutable Stone index. Only content identities are
// repeated here, so the index remains the single metadata authority.

let arrays = import! std.array.prim
let package_sets = import! "./package_sets.glu"

type IndexPin = {
    sha256 : String,
    size : Int,
}

type RepositoryPin = {
    base_uri : String,
    channel : String,
    version : String,
    architecture : String,
    index : IndexPin,
}

type PackageSet = {
    total_download_bytes : Int,
    sha256 : Array String,
}

type FixtureClosure = {
    name : String,
    package_ids : Array String,
}

type BootstrapClosure = {
    schema_version : Int,
    repository : RepositoryPin,
    fixtures : Array FixtureClosure,
    packages : PackageSet,
}

let repository = {
    base_uri = "https://cdn.aerynos.dev",
    channel = "main",
    version = "history/1783706384",
    architecture = "x86_64",
    index = {
        sha256 = "0f986f19f4e88f74ed5ae3452fbd9cc34ab53915f391555952d68ac90b202efc",
        size = 2432187,
    },
}

let package_slice = arrays.slice package_sets.all
let merge = arrays.append
let system_integration_assets_packages =
    merge (package_slice 1 6)
        (merge (package_slice 7 8)
        (merge (package_slice 9 11)
        (merge (package_slice 12 15)
        (merge (package_slice 16 17)
        (merge (package_slice 18 39)
        (merge (package_slice 40 46)
        (merge (package_slice 47 49)
        (merge (package_slice 50 52)
        (merge (package_slice 53 55)
        (merge (package_slice 56 63)
        (merge (package_slice 65 68)
        (merge (package_slice 69 79)
        (merge (package_slice 80 81)
        (merge (package_slice 82 94)
        (merge (package_slice 95 97)
        (merge (package_slice 99 102)
        (merge (package_slice 103 109)
        (merge (package_slice 110 115)
        (merge (package_slice 116 130)
        (merge (package_slice 131 134)
        (merge (package_slice 138 147)
            (package_slice 148 149))))))))))))))))))))))

{
    schema_version = 2,
    repository,
    fixtures = [
        { name = "autotools", package_ids = package_sets.autotools },
        { name = "autotools-options", package_ids = package_sets.autotools },
        { name = "cargo", package_ids = package_sets.cargo },
