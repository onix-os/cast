let b = import! cast.package.v3

let domain = "cast-gettext-localization-fixture"

let phases = b.scripts {
    setup = b.phase [
        b.step.run (b.program.binary "mkdir") ["-p", "build/locale/fr/LC_MESSAGES"],
        b.step.run (b.program.binary "mkdir") ["-p", "build/locale/de/LC_MESSAGES"],
    ],
    build = b.phase [
        b.step.run (b.program.binary "msgfmt") [
            "--check-format",
            "--check-header",
            "-o",
            "build/locale/fr/LC_MESSAGES/cast-gettext-localization-fixture.mo",
            "po/fr.po",
        ],
        b.step.run (b.program.binary "msgfmt") [
            "--check-format",
            "--check-header",
            "-o",
            "build/locale/de/LC_MESSAGES/cast-gettext-localization-fixture.mo",
            "po/de.po",
        ],
        b.step.run (b.program.binary "cc") [
            "-std=c11",
            "-O2",
            "-g",
            "-Wall",
            "-Wextra",
            "-Werror",
            "-fstack-protector-strong",
            "-D_FORTIFY_SOURCE=3",
            "-fPIE",
            "consumer.c",
            "-Wl,-pie",
            "-Wl,--build-id=sha1",
            "-Wl,-z,relro,-z,now",
            "-Wl,-z,noexecstack",
            "-Wl,-z,separate-code",
            "-Wl,--as-needed",
            "-o",
            "build/gettext-consumer",
        ],
    ],
    check = b.phase [
        b.step.run_built
            (b.program.built "build/gettext-consumer")
            ["fr_FR.utf8", "build/locale", "Bonjour de Cast"],
        b.step.run_built
            (b.program.built "build/gettext-consumer")
            ["de_DE.utf8", "build/locale", "Hallo von Cast"],
    ],
    install = b.phase [
        b.step.shell_with {
            interpreter = b.program.binary "bash",
            declared_programs = [b.program.binary "install"],
            script = r#"install -Dm644 build/locale/fr/LC_MESSAGES/cast-gettext-localization-fixture.mo "${CAST_INSTALL_ROOT}${CAST_DATADIR}/locale/fr/LC_MESSAGES/cast-gettext-localization-fixture.mo"
install -Dm644 build/locale/de/LC_MESSAGES/cast-gettext-localization-fixture.mo "${CAST_INSTALL_ROOT}${CAST_DATADIR}/locale/de/LC_MESSAGES/cast-gettext-localization-fixture.mo"
install -Dm644 COPYING "${CAST_INSTALL_ROOT}${CAST_DATADIR}/licenses/cast-gettext-localization-fixture/COPYING""#,
        },
    ],
    .. b.defaults.scripts
}

let root = b.output_with {
    summary = b.optional.set "Compiled French and German gettext catalogs",
    description = b.optional.set "Two validated message catalogs whose translations are exercised by a build-only libc gettext consumer.",
    paths = [
        b.path.any "/usr/share/locale/fr/LC_MESSAGES/cast-gettext-localization-fixture.mo",
        b.path.any "/usr/share/locale/de/LC_MESSAGES/cast-gettext-localization-fixture.mo",
        b.path.any "/usr/share/licenses/cast-gettext-localization-fixture/COPYING",
    ],
    .. b.output "out"
}

let base = b.mk_package (b.meta {
    pname = domain,
    version = "1.0.0",
    release = 1,
    homepage = "https://fixtures.invalid/cast-gettext-localization-fixture",
    license = ["MPL-2.0"],
})

{
    builder = b.builder.custom phases [
        b.dep.binary "mkdir",
        b.dep.binary "msgfmt",
        b.dep.binary "cc",
        b.dep.binary "bash",
        b.dep.binary "install",
    ],
    outputs = [root],
    sources = [
        b.source.archive_with {
            url = "https://fixtures.invalid/sources/cast-gettext-localization-fixture-1.0.0.tar",
            hash = "1e6b0b3267767853eb622e4155d3c50ecff677f8f3b305f5e4e1470f91fc1e5d",
            rename = b.optional.set "cast-gettext-localization-fixture.tar",
            strip_dirs = b.optional.set 1,
            unpack = b.boolean.true,
            unpack_dir = b.optional.set "cast-gettext-localization-fixture",
        },
    ],
    architectures = ["x86_64"],
    .. base
}
