let b = import! cast.package.v3

let phases = b.scripts {
    install = b.phase [
        b.step.shell_with {
            interpreter = b.program.binary "dash",
            declared_programs = [b.program.binary "install"],
            script = r#"install -Dm755 integration/cast-system-integration-fixture "${CAST_INSTALL_ROOT}/usr/libexec/cast-system-integration-fixture"
install -Dm644 integration/cast-system-integration-fixture.service "${CAST_INSTALL_ROOT}${CAST_LIBDIR}/systemd/system/cast-system-integration-fixture.service"
install -Dm644 integration/cast-system-integration-fixture.sysusers "${CAST_INSTALL_ROOT}${CAST_LIBDIR}/sysusers.d/cast-system-integration-fixture.conf"
install -Dm644 integration/cast-system-integration-fixture.tmpfiles "${CAST_INSTALL_ROOT}${CAST_LIBDIR}/tmpfiles.d/cast-system-integration-fixture.conf"
install -Dm644 integration/70-cast-system-integration-fixture.rules "${CAST_INSTALL_ROOT}${CAST_LIBDIR}/udev/rules.d/70-cast-system-integration-fixture.rules"
install -Dm644 integration/io.cast.SystemIntegrationFixture.rules "${CAST_INSTALL_ROOT}${CAST_DATADIR}/polkit-1/rules.d/io.cast.SystemIntegrationFixture.rules"
install -Dm644 integration/io.cast.SystemIntegrationFixture.policy "${CAST_INSTALL_ROOT}${CAST_DATADIR}/polkit-1/actions/io.cast.SystemIntegrationFixture.policy"
install -Dm644 LICENSE "${CAST_INSTALL_ROOT}${CAST_DATADIR}/licenses/cast-system-integration-assets-fixture/LICENSE""#,
        },
    ],
    check = b.phase [
        b.step.shell_with {
            interpreter = b.program.binary "dash",
            declared_programs = [],
            script = r#""${CAST_INSTALL_ROOT}/usr/libexec/cast-system-integration-fixture" --self-test"#,
        },
        b.step.shell_with {
            interpreter = b.program.binary "dash",
            declared_programs = [
                b.program.binary "systemd-analyze",
                b.program.binary "systemd-sysusers",
                b.program.binary "systemd-tmpfiles",
                b.program.binary "udevadm",
                b.program.binary "xmllint",
            ],
            script = r#"SYSTEMD_UNIT_PATH=/usr/lib/systemd/system systemd-analyze --root="${CAST_INSTALL_ROOT}" --recursive-errors=no --man=no --generators=no verify cast-system-integration-fixture.service
systemd-sysusers --dry-run --root="${CAST_INSTALL_ROOT}" "${CAST_INSTALL_ROOT}/usr/lib/sysusers.d/cast-system-integration-fixture.conf"
systemd-tmpfiles --create --dry-run --root="${CAST_INSTALL_ROOT}" --graceful -E "${CAST_INSTALL_ROOT}/usr/lib/tmpfiles.d/cast-system-integration-fixture.conf"
udevadm verify --root="${CAST_INSTALL_ROOT}" --resolve-names=never --no-summary --no-style /usr/lib/udev/rules.d/70-cast-system-integration-fixture.rules
xmllint --nonet --noout "${CAST_INSTALL_ROOT}/usr/share/polkit-1/actions/io.cast.SystemIntegrationFixture.policy""#,
        },
    ],
    .. b.defaults.scripts
}

let root = b.output_with {
    summary = b.optional.set "Declarative system integration assets fixture",
    description = b.optional.set "A staged helper plus systemd, sysusers, tmpfiles, udev, and self-contained polkit declarations with offline syntax checks.",
    runtime_inputs = [
        b.dep.binary "dash",
        b.dep.package "systemd",
        b.dep.package "systemd-sysusers",
        b.dep.package "systemd-tmpfiles",
        b.dep.package "systemd-udev",
        b.dep.package "polkit",
    ],
    paths = [
        b.path.exe "/usr/libexec/cast-system-integration-fixture",
        b.path.any "/usr/lib/systemd/system/cast-system-integration-fixture.service",
        b.path.any "/usr/lib/sysusers.d/cast-system-integration-fixture.conf",
        b.path.any "/usr/lib/tmpfiles.d/cast-system-integration-fixture.conf",
        b.path.any "/usr/lib/udev/rules.d/70-cast-system-integration-fixture.rules",
        b.path.any "/usr/share/polkit-1/rules.d/io.cast.SystemIntegrationFixture.rules",
        b.path.any "/usr/share/polkit-1/actions/io.cast.SystemIntegrationFixture.policy",
        b.path.any "/usr/share/licenses/cast-system-integration-assets-fixture/LICENSE",
    ],
    .. b.output "out"
}

let base = b.mk_package (b.meta {
    pname = "cast-system-integration-assets-fixture",
    version = "1.0.0",
    release = 1,
    homepage = "https://fixtures.invalid/cast-system-integration-assets-fixture",
    license = ["MPL-2.0"],
})

{
    builder = b.builder.custom phases [
        b.dep.binary "dash",
        b.dep.binary "install",
    ],
    check_inputs = [
        b.dep.binary "systemd-analyze",
        b.dep.binary "systemd-sysusers",
        b.dep.binary "systemd-tmpfiles",
        b.dep.binary "udevadm",
        b.dep.binary "xmllint",
    ],
    outputs = [root],
    sources = [
        b.source.archive_with {
            url = "https://fixtures.invalid/sources/cast-system-integration-assets-fixture-1.0.0.tar",
            hash = "27d04653529db216023599d2f6122f503acb59e0ebe26c5bce351dc970d58113",
            rename = b.optional.set "cast-system-integration-assets-fixture.tar",
            strip_dirs = b.optional.set 1,
            unpack = b.boolean.true,
            unpack_dir = b.optional.set "cast-system-integration-assets-fixture",
        },
    ],
    .. base
}
