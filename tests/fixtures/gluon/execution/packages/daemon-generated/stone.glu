
let b = import! cast.package.v3
let cmake = import! cast.builders.cmake.v2

let pname = "cast-daemon-fixture"

let root = b.output_with {
    summary = b.optional.set "Daemon fixture, service unit, and generated defaults",
    paths = [
        b.path.exe "/usr/sbin/cast-daemon-fixture",
        b.path.any "/usr/lib/systemd/system/cast-daemon.service",
        b.path.any "/usr/share/defaults/cast-daemon-fixture",
    ],
    .. b.output "out"
}

let documentation = b.output_with {
    include_in_manifest = b.boolean.false,
    summary = b.optional.set "Daemon fixture administrator manual",
    paths = [b.path.any "/usr/share/man/man8/cast-daemon.8"],
    .. b.output "docs"
}

let debugging = b.output_with {
    include_in_manifest = b.boolean.false,
    summary = b.optional.set "Daemon fixture debugging symbols",
    paths = [b.path.any "/usr/lib/debug"],
    .. b.output "dbginfo"
}

let base = b.mk_package (b.meta {
    pname,
    version = "1.0.0",
    release = 1,
    homepage = "https://fixtures.invalid/cast-daemon-fixture",
    license = ["MPL-2.0"],
})

{
    builder = cmake.default,
    outputs = [root, documentation, debugging],
    sources = [
        b.source.archive_with {
            url = "https://fixtures.invalid/sources/cast-daemon-fixture-1.0.0.tar.zst",
            hash = "7d01ab16acc6b96925e8f996e8fbaea4d11b448bccc44d40090bbdc7963e617b",
            rename = b.optional.set "cast-daemon-fixture.tar.zst",
            strip_dirs = b.optional.set 1,
            unpack = b.boolean.true,
            unpack_dir = b.optional.set "cast-daemon-fixture",
        },
    ],
    .. base
}
