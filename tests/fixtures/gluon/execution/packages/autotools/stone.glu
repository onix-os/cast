
let b = import! cast.package.v3
let autotools = import! cast.builders.autotools.v2

let base = b.mk_package (b.meta {
    pname = "cast-autotools-fixture",
    version = "1.0.0",
    release = 1,
    homepage = "https://fixtures.invalid/cast-autotools-fixture",
    license = ["MPL-2.0"],
})

{
    builder = autotools.default,
    hooks = b.hooks {
        // Regenerate the build system from authored Autoconf/Automake inputs.
        // The program binding and native dependency are both explicit so the
        // frozen plan retains the executable and dependency-role origins.
        pre_setup = [
            b.step.run (b.program.binary "autoreconf") ["-fi"],
        ],
        .. b.defaults.hooks
    },
    native_build_inputs = [b.dep.binary "autoreconf"],
    sources = [
        b.source.archive_with {
            url = "https://fixtures.invalid/sources/cast-autotools-fixture-1.0.0.tar",
            hash = "cc72bc585ef513808277602603a6d883d0d9b8722a84e43fe65090035accf394",
            rename = b.optional.set "cast-autotools-fixture.tar",
            strip_dirs = b.optional.set 1,
            unpack = b.boolean.true,
            unpack_dir = b.optional.set "cast-autotools-fixture",
        },
    ],
    .. base
}
