let b = import! boulder.package.v2
let meson = import! boulder.builders.meson.v1

let root = {
    summary = b.optional.set "Package creation tool for Serpent OS",
    description = b.optional.set "Flexible package build tooling for Serpent OS.",
    runtime_inputs = [b.dep.binary "moss-container"],
    .. b.output "out"
}

let base = b.mk_package (b.meta {
    pname = "boulder",
    version = "1.0.1",
    release = 35,
    homepage = "https://github.com/serpent-os/boulder",
    license = ["Zlib"],
})

{
    builder = meson.builder {
        flags = ["--buildtype", "debugoptimized"],
        run_tests = b.boolean.false,
    },
    hooks = {
        post_install = ["ln -sf boulder %(installroot)/usr/bin/mason"],
        environment = ["cd %(buildroot)/boulder"],
        .. b.defaults.hooks
    },
    build_inputs = [
        b.dep.package "ldc",
        b.dep.package "ldc-devel",
        b.dep.package "lmdb-devel",
        b.dep.pkgconfig "libcurl",
        b.dep.pkgconfig "libxxhash",
        b.dep.pkgconfig "libzstd",
    ],
    outputs = [root],
    sources = [
        b.source.git "https://github.com/serpent-os/boulder" "v1.0.1",
        b.source.archive_with {
            url = "https://github.com/serpent-os/libmoss/releases/download/v1.2.0/libmoss-1.2.0.tar.xz",
            hash = "cbf684b5a37a3a433e0526beb04a7b3419b71e81b3709c3b0d7ed6a1987d3dcb",
            rename = b.optional.unset,
            strip_dirs = b.optional.set 1,
            unpack = b.boolean.true,
            unpack_dir = b.optional.set "libmoss",
        },
    ],
    .. base
}
